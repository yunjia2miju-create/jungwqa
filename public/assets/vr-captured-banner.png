<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 800 300" width="100%" height="100%">
  <defs>
    <!-- Background image shadow and rounded corner clip path -->
    <clipPath id="rounded-corners">
      <rect width="800" height="300" rx="16" ry="16" />
    </clipPath>
    <!-- Dark Emerald Overlay Gradient -->
    <linearGradient id="emerald-grad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#022c22" stop-opacity="0.85" />
      <stop offset="60%" stop-color="#042f2e" stop-opacity="0.75" />
      <stop offset="100%" stop-color="#064e3b" stop-opacity="0.9" />
    </linearGradient>
    <!-- Glow filter for VR Text -->
    <filter id="neon-glow" x="-20%" y="-20%" width="140%" height="140%">
      <feGaussianBlur stdDeviation="6" result="blur" />
      <feMerge>
        <feMergeNode in="blur" />
        <feMergeNode in="SourceGraphic" />
      </feMerge>
    </filter>
  </defs>

  <!-- Main Container with Clip Path for Rounded Corners -->
  <g clip-path="url(#rounded-corners)">
    <!-- Background Image (Luxury Modern Room) -->
    <image href="https://images.unsplash.com/photo-1600210492486-724fe5c67fb0?auto=format&amp;fit=crop&amp;w=800&amp;h=300&amp;q=80" x="0" y="0" width="800" height="300" preserveAspectRatio="xMidYMid slice" />
    
    <!-- Gradient Overlay -->
    <rect width="800" height="300" fill="url(#emerald-grad)" />

    <!-- VR Virtual Grid Accents (Techy lines) -->
    <path d="M 0,50 L 800,50 M 0,100 L 800,100 M 0,150 L 800,150 M 0,200 L 800,200 M 0,250 L 800,250" stroke="#10b981" stroke-opacity="0.08" stroke-width="1" />
    <path d="M 100,0 L 100,300 M 200,0 L 200,300 M 300,0 L 300,300 M 400,0 L 400,300 M 500,0 L 500,300 M 600,0 L 600,300 M 700,0 L 700,300" stroke="#10b981" stroke-opacity="0.08" stroke-width="1" />

    <!-- Tech borders -->
    <rect x="8" y="8" width="784" height="284" rx="10" fill="none" stroke="#10b981" stroke-opacity="0.3" stroke-width="1.5" />
    <rect x="12" y="12" width="776" height="276" rx="8" fill="none" stroke="#ffffff" stroke-opacity="0.1" stroke-width="1" />

    <!-- Left side content group -->
    <g transform="translate(45, 0)">
      <!-- Subtitle -->
      <text x="0" y="85" font-family="'Malgun Gothic', '맑은 고딕', sans-serif" font-weight="bold" font-size="14" fill="#10b981" letter-spacing="1">TAEWANG REAL ESTATE PREMIUM VR</text>
      
      <!-- Main Title -->
      <text x="0" y="135" font-family="'Malgun Gothic', '맑은 고딕', sans-serif" font-weight="bold" font-size="34" fill="#ffffff" letter-spacing="1">태왕 전용 360° VR 실감투어</text>
      
      <!-- Highlight Description -->
      <text x="0" y="175" font-family="'Malgun Gothic', '맑은 고딕', sans-serif" font-weight="bold" font-size="15" fill="#34d399">현장 방문 전, 손가락 터치만으로 완벽한 가상 임장을 경험하세요!</text>
      
      <!-- Action instruction -->
      <g transform="translate(0, 195)">
        <!-- Small green bullet -->
        <circle cx="6" cy="18" r="4" fill="#10b981" />
        <text x="18" y="22" font-family="'Malgun Gothic', '맑은 고딕', sans-serif" font-size="13" fill="#94a3b8">아래 배너를 클릭하시면 해당 매물의 3D VR 화면으로 즉시 연결됩니다.</text>
      </g>
    </g>

    <!-- Right side Play / Interaction Group -->
    <g transform="translate(630, 150)">
      <!-- Animated looking radar rings -->
      <circle cx="0" cy="0" r="60" fill="none" stroke="#10b981" stroke-opacity="0.15" stroke-width="1" />
      <circle cx="0" cy="0" r="48" fill="none" stroke="#10b981" stroke-opacity="0.25" stroke-width="2" />
      <circle cx="0" cy="0" r="36" fill="#10b981" fill-opacity="0.2" />
      
      <!-- Play Button Circle -->
      <circle cx="0" cy="0" r="28" fill="#10b981" filter="url(#neon-glow)" />
      
      <!-- Play Arrow Icon (Triangle) -->
      <polygon points="-6,-10 12,0 -6,10" fill="#ffffff" />
      
      <!-- Glowing ring -->
      <circle cx="0" cy="0" r="28" fill="none" stroke="#34d399" stroke-width="1.5" stroke-opacity="0.8" />
      
      <!-- Click guide text under button -->
      <text x="0" y="55" text-anchor="middle" font-family="'Malgun Gothic', '맑은 고딕', sans-serif" font-weight="bold" font-size="12" fill="#ffffff" filter="url(#neon-glow)">CLICK TO PLAY</text>
    </g>
  </g>
</svg>
