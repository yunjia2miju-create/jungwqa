rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global Safety Net (Default Deny Catch-all)
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() 
        && request.auth.token.email == "yunjia2miju@gmail.com";
    }

    function isValidId(id) {
      return id is string 
        && id.size() <= 128 
        && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Validation Functions for Entities ---
    function isValidPost(data) {
      return data.keys().hasAll(['id', 'category', 'dong', 'building', 'room', 'price', 'manageFee', 'phone', 'title', 'address', 'transactionType', 'isRecommended', 'createdAt'])
        && data.keys().size() <= 40
        && data.id is string
        && data.id.size() <= 256
        && data.category is string
        && data.category.size() <= 100
        && data.dong is string
        && data.dong.size() <= 100
        && data.building is string
        && data.building.size() <= 500
        && data.room is string
        && data.room.size() <= 150
        && data.price is string
        && data.price.size() <= 500
        && data.manageFee is string
        && data.manageFee.size() <= 500
        && data.phone is string
        && data.phone.size() <= 100
        && data.title is string
        && data.title.size() <= 2000
        && data.address is string
        && data.address.size() <= 1000
        && data.transactionType is string
        && data.transactionType.size() <= 100
        && data.isRecommended is bool
        && data.createdAt is int
        && (!('floor' in data) || (data.floor is string && data.floor.size() <= 100))
        && (!('totalFloor' in data) || (data.totalFloor is string && data.totalFloor.size() <= 100))
        && (!('ownerPhone' in data) || (data.ownerPhone is string && data.ownerPhone.size() <= 150))
        && (!('remarks' in data) || (data.remarks is string && data.remarks.size() <= 10000))
        && (!('intro' in data) || (data.intro is string && data.intro.size() <= 5000))
        && (!('body' in data) || (data.body is string && data.body.size() <= 200000))
        && (!('video' in data) || (data.video is string && data.video.size() <= 2000))
        && (!('panoImage' in data) || (data.panoImage is string && data.panoImage.size() <= 2000))
        && (!('thumbnail' in data) || (data.thumbnail is string && data.thumbnail.size() <= 2000000))
        && (!('images' in data) || (data.images is string && data.images.size() <= 10000000))
        && (!('panoramas' in data) || (data.panoramas is string && data.panoramas.size() <= 10000000));
    }

    function isValidInquiry(data) {
      return data.keys().hasAll(['id', 'name', 'phone', 'message', 'processed', 'createdAt'])
        && data.id is string
        && data.id.size() <= 128
        && data.name is string
        && data.name.size() <= 100
        && data.phone is string
        && data.phone.size() <= 50
        && data.message is string
        && data.message.size() <= 5000
        && data.processed is bool
        && data.createdAt is int;
    }

    function isValidRegisteredUser(data) {
      return data.keys().hasAll(['email', 'name', 'phone', 'createdAt', 'approved', 'provider'])
        && data.email is string
        && data.email.size() <= 128
        && data.name is string
        && data.name.size() <= 100
        && data.phone is string
        && data.phone.size() <= 50
        && data.createdAt is string
        && data.createdAt.size() <= 100
        && data.approved is bool
        && data.provider is string
        && data.provider.size() <= 50;
    }

    // --- Path Match Rules ---

    // 1. Posts (매물 장부)
    match /posts/{postId} {
      // Anyone can search and read listings
      allow read: if true;
      
      // Admins (and only the authorized email) can register, edit, and delete listings
      allow create: if isAdmin() 
        && isValidId(postId) 
        && isValidPost(request.resource.data);
        
      allow update: if isAdmin() 
        && isValidPost(request.resource.data);
        
      allow delete: if isAdmin();
    }

    // 2. Inquiries (상담 의뢰 접수)
    match /inquiries/{inquiryId} {
      // Anyone can submit raw inquiries (to facilitate prospective client booking)
      allow create: if isValidId(inquiryId) 
        && isValidInquiry(request.resource.data);
        
      // Only the admin can view, change status, or purge inquiries
      allow read: if isAdmin();
      allow update: if isAdmin() && isValidInquiry(request.resource.data);
      allow delete: if isAdmin();
    }

    // 3. Registered Users (등록 회원 관리)
    match /registered_users/{email} {
      // Allow read so client-side password verification can be checked on pre-auth phases
      allow read: if true;
      
      // Allow clients to register themselves with pending (approved = false) status
      allow create: if isValidRegisteredUser(request.resource.data)
        && (isAdmin() || request.resource.data.approved == false);
        
      // Allow admins to update or process state, and preserve user details if still waiting for permission
      allow update: if isValidRegisteredUser(request.resource.data)
        && (isAdmin() || (request.resource.data.approved == false && resource.data.approved == false));
        
      allow delete: if isAdmin();
    }
  }
}
